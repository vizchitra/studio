{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "ignorePatterns": [
    "**/.svelte-kit/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/.wrangler/**",
    "migrations/**",
    "**/*.md"
  ]
}
